# Discord
DISCORD_TOKEN=replace_me
RUST_LOG=info

# App
DEFAULT_BOT_NAME=Buzzkeeper
DEFAULT_THEME=tavern
STORAGE_PATH=data/tavern-state.json

# LLM defaults
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=qwen3:4b
LLM_TEMPERATURE=0.9
LLM_MAX_TOKENS=240
LLM_TIMEOUT_SECS=30

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=
OPENAI_ORGANIZATION=
OPENAI_PROJECT=

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_MODEL=

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GOOGLE_MODEL=

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_KEEP_ALIVE=10m

# Hive / Hive Engine polling
HIVE_API_URL=https://api.hive.blog
HIVE_ENGINE_API_URL=https://api.hive-engine.com/rpc/blockchain
HIVE_HISTORY_BATCH_SIZE=100
PAYMENT_TIMEOUT_SECS=20
PAYMENT_POLL_INTERVAL_SECS=15
